# ==========================================
# Application
# ==========================================

APP_ENV=development
APP_NAME=Billsons Network
SECRET_KEY=change-me

# ==========================================
# Encryption
# ==========================================

ENCRYPTION_KEY=change-me

# ==========================================
# Database
# ==========================================

POSTGRES_DB=billsons_network
POSTGRES_USER=billsons_network
POSTGRES_PASSWORD=change-me

DATABASE_URL=postgresql+psycopg://billsons_network:change-me@db:5432/billsons_network

# ==========================================
# Session
# ==========================================

SESSION_TIMEOUT_MINUTES=480

# ==========================================
# Upload Limits
# ==========================================

DEVICE_PHOTO_MAX_MB=5
ICON_UPLOAD_MAX_MB=2

# ==========================================
# Timezone
# ==========================================

DEFAULT_TIMEZONE=UTC